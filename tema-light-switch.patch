+   ------------------------------------------------------------ */
+[data-theme="light"] .text-white     { color: rgb(var(--gb-fg-rgb)); }
+[data-theme="light"] .text-white\/95 { color: rgba(var(--gb-fg-rgb), 0.95); }
+[data-theme="light"] .text-white\/90 { color: rgba(var(--gb-fg-rgb), 0.90); }
+[data-theme="light"] .text-white\/85 { color: rgba(var(--gb-fg-rgb), 0.85); }
+[data-theme="light"] .text-white\/80 { color: rgba(var(--gb-fg-rgb), 0.82); }
+[data-theme="light"] .text-white\/75 { color: rgba(var(--gb-fg-rgb), 0.78); }
+[data-theme="light"] .text-white\/70 { color: rgba(var(--gb-fg-rgb), 0.75); }
